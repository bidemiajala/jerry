{
  "name": "e2e-lab",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "description": "QE Lab — AI-driven Quality Engineering Platform with self-healing tests, LLM test generation, and real-time observability.",
  "homepage": "https://github.com/bidemiajala/e2e-lab#readme",
  "license": "ISC",
  "author": "Demi Ajala",
  "scripts": {
    "dev": "cd frontend && npm run dev",
    "build": "cd frontend && npm run build",
    "start": "cd frontend && npm run start",
    "install:all": "npm install && cd frontend && npm install",
    "test:playwright": "playwright test",
    "test:playwright:ui": "playwright test --ui",
    "test:playwright:demo": "playwright test playwright/demo-onboarding.spec.ts",
    "test:playwright:healing": "playwright test playwright/self-healing.spec.ts",
    "lint": "cd frontend && npm run lint"
  },
  "devDependencies": {
    "@playwright/test": "1.42.1",
    "@types/node": "20.11.24",
    "eslint-plugin-playwright": "1.5.2"
  }
}
